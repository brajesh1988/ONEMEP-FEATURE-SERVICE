# Stop Lombok from searching parent directories for further config.
config.stopBubbling = true

# Copy Spring's injection/qualifier annotations from fields onto the parameters
# of the constructor generated by @RequiredArgsConstructor/@AllArgsConstructor.
# Without this, @Qualifier on a `private final` field is silently dropped and
# Spring falls back to the @Primary bean (which broke jwtDecoderIgnoringExpiry).
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Qualifier
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Value
