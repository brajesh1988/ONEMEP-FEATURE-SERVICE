{
  "info": {
    "name": "ONEMEP Feature Service",
    "_postman_id": "6f2a1c4e-8b1d-4d2a-9c3e-featureservice01",
    "description": "End-to-end collection for ONEMEP-FEATURE-SERVICE (Projects + Master Data) via the API Gateway.\n\nHOW TO USE\n1. Select the environment (baseUrl / email / password) or use the collection variable defaults.\n2. Run **Auth > Login** first — its test script stores `accessToken` (and `refreshToken`) as collection variables.\n3. All other requests inherit Bearer `{{accessToken}}` automatically.\n4. Create requests store the returned id into variables (e.g. `categoryId`, `projectId`) so the Get/Update/Patch requests work without editing.\n\nAll paths go through the gateway WITHOUT the `/feature-service` context path (the gateway rewrites it).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://16.192.90.23:9000" },
    { "key": "email", "value": "user@onemep.com" },
    { "key": "password", "value": "ChangeMe@123" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "categoryId", "value": "1" },
    { "key": "tierId", "value": "1" },
    { "key": "teamRoleId", "value": "1" },
    { "key": "unitId", "value": "1" },
    { "key": "technicalId", "value": "1" },
    { "key": "handlingOfficeId", "value": "1" },
    { "key": "detailingLevelId", "value": "1" },
    { "key": "projectId", "value": "1" },
    { "key": "specSheetId", "value": "1" },
    { "key": "deliveryItemId", "value": "1" },
    { "key": "stakeholderId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const b = pm.response.json();",
                  "pm.test('login ok', () => pm.expect(pm.response.code).to.eql(200));",
                  "const d = b.data || {};",
                  "if (d.accessToken) { pm.collectionVariables.set('accessToken', d.accessToken); }",
                  "if (d.refreshToken) { pm.collectionVariables.set('refreshToken', d.refreshToken); }",
                  "if (d.twoFactorRequired) { console.warn('2FA required — complete /auth/2fa flow to obtain a token'); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = (pm.response.json().data) || {};",
                  "if (d.accessToken) pm.collectionVariables.set('accessToken', d.accessToken);",
                  "if (d.refreshToken) pm.collectionVariables.set('refreshToken', d.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        }
      ]
    },
